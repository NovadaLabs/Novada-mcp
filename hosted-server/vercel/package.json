{
  "name": "novada-mcpserver",
  "version": "0.1.0",
  "private": true,
  "description": "Vercel Function (Node.js runtime) hosting Novada MCP as a remote Streamable HTTP endpoint at https://mcp.novada.com/mcp",
  "type": "module",
  "scripts": {
    "dev": "vercel dev",
    "deploy": "vercel deploy --prod",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "test": "node --test \"test/**/*.test.mjs\"",
    "sync:hosted": "node ../scripts/sync-to-hosted.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@sentry/node": "^10.62.0",
    "@vercel/kv": "^1.0.0",
    "axios": "^1.15.0",
    "cheerio": "^1.2.0",
    "exceljs": "^4.4.0",
    "form-data": "^4.0.6",
    "pdf-parse": "^2.4.5",
    "playwright-core": "^1.61.1",
    "turndown": "^7.2.4",
    "turndown-plugin-gfm": "^1.0.2",
    "zod": "^4.3.6"
  },
  "overrides": {
    "form-data": "^4.0.6",
    "undici": "^7.28.0",
    "@vercel/blob": {
      "undici": "^6.27.0"
    }
  },
  "devDependencies": {
    "@types/node": "^22",
    "typescript": "^5.5.4",
    "vercel": "latest"
  }
}
